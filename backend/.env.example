# ============================================
# CONFIGURACIÓN DE BASE DE DATOS (PostgreSQL)
# ============================================

# Este proyecto usa PostgreSQL en Neon (base de datos en la nube)
# Cada integrante debe:
# 1. Aceptar la invitación al proyecto en Neon
# 2. Ir a "Connection Details" dentro del proyecto o "Connection"
# 3. Copiar su connection string de "tareasdb"
# 4. Copiarla en el .env

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require"